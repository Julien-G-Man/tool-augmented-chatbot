# Database (SQL Server)
# Use one DATABASE_URL line that matches your local SQL Server setup.

# SQL login auth example (username/password):
# DATABASE_URL="mssql+pyodbc://sa:your_password@localhost:1433/CompanyDB?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes"

# Windows integrated auth example (trusted connection):
# DATABASE_URL="mssql+pyodbc://@localhost/CompanyDB?driver=ODBC+Driver+18+for+SQL+Server&trusted_connection=yes&TrustServerCertificate=yes"

DATABASE_URL=""

# NVIDIA-hosted OpenAI-compatible API
NVIDIA_OPENAI_API_KEY="your_real_api_key_here"
NVIDIA_OPENAI_API_URL="https://integrate.api.nvidia.com/v1/chat/completions"
NVIDIA_OPENAI_MODEL="openai/gpt-oss-20b"
